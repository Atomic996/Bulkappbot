rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: trades
    // Document ID: auto-generated
    // Fields: symbol, price, size, side, walletId, timestamp
    //
    // Collection: wallets
    // Document ID: walletId
    // Fields: id, position, entryPrice, entrySize, totalPnL, winCount, tradeCount, lastUpdate
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isServer() {
      return request.resource.data.serverKey == "bulk_flow_server_auth_key_2026_03_31";
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "chamadi.hicham123@gmail.com" && request.auth.token.email_verified == true));
    }

    match /trades/{tradeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() || isServer();
      allow update, delete: if isAdmin();
    }

    match /wallets/{walletId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() || isServer();
      allow delete: if isAdmin();
    }
    
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }
  }
}
